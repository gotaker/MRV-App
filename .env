# ===== Dev Environment Variables =====
# HTTPS origin for dev proxy
CORS_ORIGIN=https://localhost
COOKIE_SECURE=true

# Mongo (MongoDB 8)
MONGO_USER=mrv
MONGO_PASSWORD=mrvpass
MONGO_DB=mrv
MONGO_PORT=27017

# API
API_PORT=3000
API_JWT_SECRET=dev-change-me
API_JWT_EXPIRES=15m
API_REFRESH_SECRET=dev-refresh-change-me
API_REFRESH_EXPIRES=7d

# MinIO (S3 mock)
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=adminadmin
MINIO_BUCKET=mrv-files

# Mailhog
SMTP_HOST=mailhog
SMTP_PORT=1025
